# learnhermes — environment example
#
# This course runs entirely with deterministic mocks. No real API keys
# are required to make the tests pass. The variables below are
# documented so the runtime you build mirrors what real OpenClaw /
# Hermes-style runtimes need at the seams.

# --- Daemon ---
LEARNHERMES_WORKSPACE=./tmp/workspace
LEARNHERMES_PID_FILE=./tmp/workspace/runtime.pid
LEARNHERMES_LOG_LEVEL=info

# --- AI provider (mocked in tests) ---
# Tests inject a MockAIClient. Do not put a real key here.
ANTHROPIC_API_KEY=sk-mock-do-not-use

# --- Channels (mocked in tests) ---
# Real adapters would consume these; the course does not.
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=

# --- Subagents ---
LEARNHERMES_MAX_SUBAGENT_DEPTH=2
LEARNHERMES_MAX_CONCURRENT_CHILDREN=3
LEARNHERMES_CHILD_TIMEOUT_SECONDS=600

# --- Learning loop ---
LEARNHERMES_LEARNING_THRESHOLD=3
LEARNHERMES_LEARNING_REQUIRE_APPROVAL=true
